# ========================================
# OECT (Rockchip RK3566) - ImmortalWrt
# ========================================

# ---------- Target Platform ----------
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_rk3568=y
# 如果 ImmortalWrt 有针对 OECT 的专用 Profile，可改为：
# CONFIG_TARGET_rockchip_rk3568_DEVICE_oec-rk3566=y
# 否则使用 generic
CONFIG_TARGET_rockchip_rk3568_DEVICE_generic=y

# ---------- Kernel Modules ----------
# 基础网络
CONFIG_PACKAGE_kmod-tls=y
CONFIG_PACKAGE_kmod-tun=y

# 有线网卡 (OECT 通常使用 RTL8169 或 RTL8125)
CONFIG_PACKAGE_kmod-r8169=y
# CONFIG_PACKAGE_kmod-r8125=y  # 若为 2.5G 网卡

# USB 支持
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y

# 存储接口
CONFIG_PACKAGE_kmod-ata-ahci-platform=y  # SATA
CONFIG_PACKAGE_kmod-sdhci=y              # SD/TF 卡

# 文件系统
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-f2fs=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs=y

# GPIO / I2C / SPI
CONFIG_PACKAGE_kmod-gpio-button-hotplug=y
CONFIG_PACKAGE_kmod-i2c-core=y
CONFIG_PACKAGE_kmod-spi-dev=y

# ---------- Base Packages ----------
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_fuse-utils=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_sgdisk=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_qrencode=y

# ---------- Luci Applications ----------
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-app-adguardhome_INCLUDE_binary=n
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-statistics=y

# ---------- Docker Support (OECT 核心用途) ----------
CONFIG_PACKAGE_kmod-veth=y
CONFIG_PACKAGE_kmod-br-netfilter=y
CONFIG_PACKAGE_kmod-ikconfig=y
CONFIG_PACKAGE_kmod-nf-nat=y
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_docker-ce=y
CONFIG_PACKAGE_dockerd=y

# ---------- Networking ----------
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_tc=y
CONFIG_PACKAGE_ebtables=y

# ---------- Utilities ----------
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_tree=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_gzip=y

# ---------- GPT / Partition ----------
CONFIG_PACKAGE_partx-utils=y
CONFIG_PACKAGE_gptfdisk=y
CONFIG_PACKAGE_fdisk=y

# ---------- 其他可能会被脚本追加的配置 ----------
# 脚本还会自动追加 compile_base.config、docker_deps.config、proxy.config
# 以及 nss.config（如果是 IPQ 系列，OECT 不会匹配）
