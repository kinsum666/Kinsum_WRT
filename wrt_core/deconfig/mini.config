# ========== 目标平台（必须保留） ==========
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01="ipq-wifi-jdcloud_re-ss-01 -kmod-ath11k-pci zram-swap  luci-app-cupsd"
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02="ipq-wifi-jdcloud_re-cs-02 ath11k-firmware-qcn9074-ddwrt kmod-ath11k-pci luci-app-athena-led luci-i18n-athena-led-zh-cn luci-app-cupsd"
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-07=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-07="-ath11k-firmware-ipq6018-ddwrt -kmod-ath11k -kmod-ath11k-ahb -kmod-ath11k-pci luci-app-dockerman luci-i18n-dockerman-zh-cn  luci-app-cupsd"
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5-jdcloud=y
# CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_redmi_ax5-jdcloud="ipq-wifi-redmi_ax5-jdcloud -kmod-ath11k-pci zram-swap"
CONFIG_TARGET_ROOTFS_INITRAMFS=n

# ========== 核心网络支持 ==========
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-tls=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-netlink-diag=y

# ========== 文件系统（含外接硬盘支持） ==========
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-ext4=y          # 新增，Samba/分区常用
CONFIG_PACKAGE_ntfs3-mount=y
CONFIG_PACKAGE_resize2fs=y
CONFIG_PACKAGE_sgdisk=y
CONFIG_PACKAGE_fuse-utils=y
CONFIG_PACKAGE_kmod-usb-storage=y      # 新增，USB硬盘识别
CONFIG_PACKAGE_kmod-usb-storage-uas=y  # 新增，UAS加速
CONFIG_PACKAGE_kmod-usb2=y             # 新增，USB2.0支持
CONFIG_PACKAGE_kmod-usb3=y             # 新增，USB3.0支持（如亚瑟有USB3）

# ========== 系统工具 ==========
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_qrencode=y
CONFIG_PACKAGE_xz-utils=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_block-mount=y           # 新增，磁盘挂载工具

# ========== 网络诊断工具 ==========
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_mii-tool=y

# ========== 交换分区 ==========
CONFIG_PACKAGE_zram-swap=y

# ========== 核心 LuCI 应用（网络加速与分流） ==========
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_DNSFORWARDER=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_DNSPROXY=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_OFFLOADING=y
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_luci-app-ramfree=y
CONFIG_PACKAGE_luci-app-attendedsysupgrade=y

# ========== 保留 iStoreOS 应用商店 ==========
CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_luci-app-quickstart=y
CONFIG_PACKAGE_luci-i18n-quickstart-zh-cn=y

# ========== 保留 ZeroTier VPN ==========
CONFIG_PACKAGE_zerotier=y
CONFIG_PACKAGE_luci-app-zerotier=y

# ========== 新增：硬盘分区工具（图形界面） ==========
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-i18n-diskman-zh-cn=y

# ========== 新增：Samba4 网络共享 ==========
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y

# ========== 其他保留（你原来加的） ==========
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_luci-app-irqbalance=y
